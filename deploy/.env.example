# Air3 Live — server secrets. Copy to /opt/air3-live/.env on the VM and fill in.
# NEVER commit the real .env (it is git-ignored).
#   sudo chmod 600 /opt/air3-live/.env

# Port the Node app listens on (Caddy proxies to this).
PORT=8080

# Cloudflare Realtime TURN — dashboard → Realtime → TURN → your app.
CF_TURN_KEY_ID=7d2f8f63d8032fc6a79e67970fab0b96
CF_TURN_API_TOKEN=REPLACE_WITH_FRESH_CLOUDFLARE_TOKEN

# Lifetime (seconds) of issued TURN credentials. 86400 = 24h.
TURN_TTL=86400

# CORS. Use * while testing; tighten to your Pages origin in production, e.g.
#   ALLOW_ORIGIN=https://<user>.github.io
ALLOW_ORIGIN=*
